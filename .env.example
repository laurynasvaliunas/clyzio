# ─── Public (bundled into the client) ──────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token-here
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─── Build-time secrets (NEVER committed — set via EAS secrets / CI) ──────────
# Used by @rnmapbox/maps to download the native SDK during `prebuild`.
MAPBOX_DOWNLOAD_TOKEN=

# ─── Edge Functions (configure via `supabase secrets set …`) ───────────────────
# Required by every AI function
ANTHROPIC_API_KEY=
# Optional: restrict CORS to your production origin(s); comma-separated
ALLOWED_ORIGINS=
# Optional: pair with scheduled cron triggers to call daily-commute-matcher
# without exposing the service role key.
CRON_SHARED_SECRET=
# Production Expo push; without it Expo throttles anonymous senders.
EXPO_PUSH_ACCESS_TOKEN=
